# copy this into your own file named .env
# replace values with real ones
# make sure .env isn't committed to avoid leaking your data

# Supabase / PostgreSQL connection
DB_HOST=db.xxxxxxxxxxxx.supabase.co   # from Supabase project settings → Database
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password

# SQLAlchemy async URL (constructed from the above)
DATABASE_URL=postgresql+asyncpg://postgres.[xxxxxxxxxxxx]:[password]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

CITY_SERVICE_URL=http://city:8000
PUBLIC_SERVICE_URL=http://public:8000
DATA_PROCESSING_SERVICE_URL=http://data_processing:8000
ALERTS_SERVICE_URL=http://alerts:8000
ACCOUNTS_SERVICE_URL=http://accounts:8000